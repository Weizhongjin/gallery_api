DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloth_gallery
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cloth-gallery
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# TOS mode example:
# STORAGE_PROVIDER=tos
# TOS_ENDPOINT=https://tos-cn-beijing.volces.com
# TOS_REGION=cn-beijing
# TOS_BUCKET=joeffe
# TOS_CREDENTIALS_FILE=/Users/weizhongjin/develop_program/shared/third-party/toc/AccessKey.txt

EMBED_PROVIDER=infinity
EMBED_ENDPOINT=http://localhost:8001
EMBED_MODEL=Marqo/marqo-fashionSigLIP
EMBED_DIMENSION=0
EMBED_API_KEY=

# Local LAN SigLIP2 example:
# EMBED_PROVIDER=infinity
# EMBED_ENDPOINT=http://192.168.0.102:8001
# EMBED_MODEL=google/siglip2-base-patch16-224

# DashScope embedding example:
# EMBED_PROVIDER=dashscope
# EMBED_MODEL=qwen3-vl-embedding
# EMBED_DIMENSION=768
VLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-plus
# Preferred key for DashScope-compatible VLM endpoint
DASHSCOPE_API_KEY=
# Optional generic override (used first if set)
VLM_API_KEY=

# Async mode: background (FastAPI BackgroundTasks) or celery (Redis + Celery worker)
ASYNC_MODE=background
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
